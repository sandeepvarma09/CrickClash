{
  "name": "cricclash-server",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build"
  },
  "deploy": {
    "startCommand": "node dist/index.js",
    "runtime": "NODE_JS",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "variables": {
    "NODE_ENV":              "production",
    "PORT":                  "5000",
    "CLIENT_URL":            "https://cricclash.app",
    "MONGO_URI":             "<set in Railway dashboard>",
    "JWT_SECRET":            "<set in Railway dashboard>",
    "JWT_EXPIRE":            "7d",
    "CRICKET_API_KEY":       "<set in Railway dashboard>",
    "CRICKET_API_BASE_URL":  "https://api.cricapi.com/v1",
    "ADMIN_USERNAME":        "<set in Railway dashboard>",
    "ADMIN_PASSWORD":        "<set in Railway dashboard>"
  }
}
